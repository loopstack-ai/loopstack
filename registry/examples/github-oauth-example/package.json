{
  "name": "@loopstack/github-oauth-example",
  "displayName": "GitHub OAuth Example",
  "description": "An example module demonstrating how to list GitHub repositories and issues with OAuth authentication using the Loopstack automation framework. Shows the sub-workflow pattern for handling OAuth flows.",
  "keywords": [
    "example",
    "github",
    "loopstack",
    "oauth"
  ],
  "version": "0.1.0",
  "license": "Apache-2.0",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/ai-module": "^0.20.6",
    "@loopstack/common": "^0.23.0",
    "@loopstack/core": "^0.23.1",
    "@loopstack/core-ui-module": "^0.20.6",
    "@loopstack/create-chat-message-tool": "^0.20.6",
    "@loopstack/github-module": "^0.1.0",
    "@loopstack/oauth-module": "^0.1.5",
    "@nestjs/common": "^11.1.14",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "loopstack": {
    "installModes": [
      "add",
      "install"
    ],
    "modules": [
      {
        "path": "src/github-example.module.ts",
        "className": "GitHubExampleModule"
      },
      {
        "package": "@loopstack/oauth-module",
        "className": "OAuthModule"
      },
      {
        "package": "@loopstack/github-module",
        "className": "GitHubModule"
      }
    ],
    "workflows": [
      {
        "path": "src/workflows/github-repos-overview.workflow.ts",
        "className": "GitHubReposOverviewWorkflow",
        "propertyName": "gitHubReposOverview"
      },
      {
        "path": "src/workflows/github-agent.workflow.ts",
        "className": "GitHubAgentWorkflow",
        "propertyName": "gitHubAgent"
      },
      {
        "package": "@loopstack/oauth-module",
        "className": "OAuthWorkflow",
        "propertyName": "oAuth"
      }
    ]
  }
}
