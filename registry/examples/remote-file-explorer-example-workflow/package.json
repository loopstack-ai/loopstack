{
  "name": "@loopstack/remote-file-explorer-example-workflow",
  "displayName": "Remote File Explorer Example",
  "description": "Example workflow demonstrating @loopstack/remote-file-explorer-module — lists a remote workspace tree and reads a file",
  "keywords": [
    "example",
    "remote-agent",
    "file-explorer",
    "workflow"
  ],
  "version": "0.21.7",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.29.0",
    "@loopstack/core": "^0.29.0",
    "@loopstack/remote-client": "^0.23.4",
    "@loopstack/remote-file-explorer-module": "^0.22.6",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "loopstack": {
    "modules": [
      {
        "path": "src/remote-file-explorer-example.module.ts",
        "className": "RemoteFileExplorerExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/remote-file-explorer-example.workflow.ts",
        "className": "RemoteFileExplorerExampleWorkflow",
        "propertyName": "remoteFileExplorerExample"
      }
    ],
    "installModes": [
      "add",
      "install"
    ]
  },
  "type": "module",
  "devDependencies": {
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
