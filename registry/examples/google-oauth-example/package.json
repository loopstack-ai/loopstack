{
  "name": "@loopstack/google-oauth-example",
  "displayName": "Google OAuth Example",
  "description": "An example module demonstrating how to interact with Google Calendar, Gmail, and Google Drive using OAuth authentication with the Loopstack automation framework. Includes a structured calendar workflow and an interactive chat agent powered by an LLM.",
  "keywords": [
    "calendar",
    "drive",
    "example",
    "gmail",
    "google",
    "loopstack",
    "oauth"
  ],
  "version": "0.3.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/claude-module": "^0.24.0",
    "@loopstack/llm-provider-module": "^0.3.0",
    "@loopstack/common": "^0.30.0",
    "@loopstack/core": "^0.30.0",
    "@loopstack/google-workspace-module": "^0.4.0",
    "@loopstack/oauth-module": "^0.3.0",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
