{
  "name": "@loopstack/google-oauth-example",
  "displayName": "Google OAuth Example",
  "description": "An example module demonstrating how to interact with Google Calendar, Gmail, and Google Drive using OAuth authentication with the Loopstack automation framework. Includes a structured calendar workflow and an interactive chat agent powered by an LLM.",
  "keywords": [
    "calendar",
    "drive",
    "example",
    "gmail",
    "google",
    "loopstack",
    "oauth"
  ],
  "version": "0.2.1",
  "license": "Apache-2.0",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/claude-module": "^0.22.0",
    "@loopstack/common": "^0.25.0",
    "@loopstack/core": "^0.25.0",
    "@loopstack/create-chat-message-tool": "^0.21.1",
    "@loopstack/google-workspace-module": "^0.3.1",
    "@loopstack/oauth-module": "^0.2.1",
    "@nestjs/common": "^11.1.14",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "loopstack": {
    "installModes": [
      "add",
      "install"
    ],
    "modules": [
      {
        "path": "src/google-example.module.ts",
        "className": "GoogleExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/workflows/calendar-summary.workflow.ts",
        "className": "CalendarSummaryWorkflow",
        "propertyName": "calendarSummary"
      },
      {
        "path": "src/workflows/google-workspace-agent.workflow.ts",
        "className": "GoogleWorkspaceAgentWorkflow",
        "propertyName": "googleWorkspaceAgent"
      }
    ]
  }
}
