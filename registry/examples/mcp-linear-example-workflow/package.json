{
  "name": "@loopstack/mcp-linear-example-workflow",
  "displayName": "MCP Linear Example",
  "description": "Example workflow that connects a chat agent to Linear's hosted MCP server through @loopstack/mcp-module",
  "keywords": [
    "example",
    "mcp",
    "linear",
    "agent",
    "workflow"
  ],
  "version": "0.2.1",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/agent": "^0.4.1",
    "@loopstack/common": "^0.31.0",
    "@loopstack/core": "^0.31.0",
    "@loopstack/mcp-module": "^0.2.1",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  }
}
