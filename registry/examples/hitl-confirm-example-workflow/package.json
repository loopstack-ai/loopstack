{
  "name": "@loopstack/hitl-confirm-example-workflow",
  "displayName": "HITL Confirm Example",
  "description": "Example workflow that uses @loopstack/hitl's ConfirmUserWorkflow to present a markdown summary and branch on the user's confirm/deny decision",
  "keywords": [
    "example",
    "hitl",
    "confirm",
    "human-in-the-loop",
    "workflow"
  ],
  "version": "0.21.6",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.28.0",
    "@loopstack/core": "^0.28.0",
    "@loopstack/hitl": "^0.1.2",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "loopstack": {
    "modules": [
      {
        "path": "src/hitl-confirm-example.module.ts",
        "className": "HitlConfirmExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/hitl-confirm-example.workflow.ts",
        "className": "HitlConfirmExampleWorkflow",
        "propertyName": "hitlConfirmExample"
      }
    ],
    "installModes": [
      "add",
      "install"
    ]
  }
}
