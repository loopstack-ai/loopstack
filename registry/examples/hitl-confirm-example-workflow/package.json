{
  "name": "@loopstack/hitl-confirm-example-workflow",
  "displayName": "HITL Confirm Example",
  "description": "Example workflow that uses @loopstack/hitl's ConfirmUserWorkflow to present a markdown summary and branch on the user's confirm/deny decision",
  "keywords": [
    "example",
    "hitl",
    "confirm",
    "human-in-the-loop",
    "workflow"
  ],
  "version": "0.23.1",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^1.0.0",
    "@loopstack/hitl": "^1.0.0",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
