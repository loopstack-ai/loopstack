{
  "name": "@loopstack/code-agent-example-workflow",
  "displayName": "Code Agent Example",
  "description": "Example workflow demonstrating @loopstack/code-agent usage with codebase exploration tools",
  "keywords": [
    "example",
    "code-agent",
    "agent",
    "workflow",
    "claude"
  ],
  "version": "0.21.5",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/agent": "^0.1.0",
    "@loopstack/code-agent": "^0.1.1",
    "@loopstack/common": "^0.27.0",
    "@loopstack/core": "^0.27.0",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "loopstack": {
    "modules": [
      {
        "path": "src/code-agent-example.module.ts",
        "className": "CodeAgentExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/code-agent-example.workflow.ts",
        "className": "CodeAgentExampleWorkflow",
        "propertyName": "codeAgentExample"
      }
    ],
    "tools": [
      {
        "package": "@loopstack/remote-client",
        "className": "GlobTool",
        "propertyName": "glob"
      },
      {
        "package": "@loopstack/remote-client",
        "className": "GrepTool",
        "propertyName": "grep"
      },
      {
        "package": "@loopstack/remote-client",
        "className": "ReadTool",
        "propertyName": "read"
      }
    ],
    "installModes": [
      "add",
      "install"
    ]
  }
}
