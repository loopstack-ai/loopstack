{
  "name": "@loopstack/delegate-error-example-workflow",
  "displayName": "Loopstack Delegate Error Example Workflow",
  "description": "A workflow demonstrating how tool validation errors and runtime errors are handled by DelegateToolCalls and fed back to the LLM.",
  "keywords": [
    "error",
    "delegate",
    "tool calling",
    "example",
    "workflow"
  ],
  "version": "0.21.7",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/claude-module": "^0.23.0",
    "@loopstack/llm-provider-module": "^0.2.0",
    "@loopstack/common": "^0.29.0",
    "@loopstack/core": "^0.29.0",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "loopstack": {
    "modules": [
      {
        "path": "src/delegate-error-example.module.ts",
        "className": "DelegateErrorExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/delegate-error.workflow.ts",
        "className": "DelegateErrorWorkflow",
        "propertyName": "delegateError"
      }
    ],
    "installModes": [
      "add",
      "install"
    ]
  },
  "type": "module",
  "devDependencies": {
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
