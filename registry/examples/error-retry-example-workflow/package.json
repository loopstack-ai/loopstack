{
  "name": "@loopstack/error-retry-example-workflow",
  "displayName": "Loopstack Error Retry Example Workflow",
  "description": "A workflow demonstrating error handling and manual retry transitions.",
  "keywords": [
    "error",
    "retry",
    "example",
    "workflow"
  ],
  "version": "0.21.5",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.27.0",
    "@loopstack/core": "^0.27.0",
    "@nestjs/common": "^11.1.19"
  },
  "files": [
    "dist",
    "src"
  ],
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "loopstack": {
    "modules": [
      {
        "path": "src/error-retry-example.module.ts",
        "className": "ErrorRetryExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/error-retry.workflow.ts",
        "className": "ErrorRetryWorkflow",
        "propertyName": "errorRetry"
      }
    ],
    "installModes": [
      "add",
      "install"
    ]
  }
}
