{
  "name": "@loopstack/advanced-workflows-examples",
  "displayName": "Loopstack Advanced Workflows Examples",
  "description": "In-depth workflow examples for advanced Loopstack patterns — state, dynamic routing, error retry, sub-workflows (parent, fan-out, sequence), batch processing, custom tools, module configuration, UI documents, agent tool-error handling.",
  "keywords": [
    "loopstack",
    "example",
    "advanced",
    "workflow",
    "state",
    "routing",
    "retry",
    "sub-workflow",
    "fan-out",
    "batch",
    "agent",
    "error-handling"
  ],
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/claude-module": "*",
    "@loopstack/common": "*",
    "@loopstack/core": "*",
    "@loopstack/llm-provider-module": "*",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
