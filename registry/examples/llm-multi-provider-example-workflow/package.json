{
  "name": "@loopstack/llm-multi-provider-example-workflow",
  "displayName": "Loopstack LLM Multi-Provider Example",
  "description": "Demonstrates using multiple LLM providers (Claude + OpenAI) in the same workflow with @InjectTool defaults",
  "keywords": [
    "loopstack",
    "example",
    "llm",
    "multi-provider",
    "claude",
    "openai"
  ],
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/agent": "^0.2.0",
    "@loopstack/claude-module": "^0.22.5",
    "@loopstack/common": "^0.28.0",
    "@loopstack/core": "^0.28.0",
    "@loopstack/llm-provider-module": "^0.1.0",
    "@loopstack/openai-module": "^0.1.0",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "loopstack": {
    "modules": [
      {
        "path": "src/llm-multi-provider-example.module.ts",
        "className": "LlmMultiProviderExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/llm-multi-provider.workflow.ts",
        "className": "LlmMultiProviderWorkflow",
        "propertyName": "llmMultiProvider"
      }
    ],
    "installModes": [
      "add"
    ]
  }
}
