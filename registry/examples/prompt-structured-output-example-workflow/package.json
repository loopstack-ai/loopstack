{
  "name": "@loopstack/prompt-structured-output-example-workflow",
  "displayName": "Loopstack Structured Prompt Output Example Workflow",
  "description": "A simple workflow showing how to work with structured LLM output in Loopstack.",
  "keywords": [
    "example",
    "json",
    "llm",
    "object",
    "prompt",
    "structured",
    "workflow"
  ],
  "version": "0.21.3",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/claude-module": "^0.22.2",
    "@loopstack/common": "^0.25.2",
    "@loopstack/core": "^0.25.2",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "loopstack": {
    "installModes": [
      "add",
      "install"
    ],
    "modules": [
      {
        "path": "src/prompt-structured-output-example.module.ts",
        "className": "PromptStructuredOutputExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/prompt-structured-output.workflow.ts",
        "className": "PromptStructuredOutputWorkflow",
        "propertyName": "promptStructuredOutput"
      }
    ]
  }
}
