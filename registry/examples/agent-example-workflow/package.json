{
  "name": "@loopstack/agent-example-workflow",
  "displayName": "Agent Example",
  "description": "Example workflow that launches @loopstack/agent's AgentWorkflow as a sub-workflow with custom tools",
  "keywords": [
    "example",
    "agent",
    "workflow",
    "claude",
    "sub-workflow"
  ],
  "version": "0.3.2",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/agent": "^1.0.0",
    "@loopstack/common": "^1.0.0",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
