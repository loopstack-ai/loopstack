{
  "name": "@loopstack/dynamic-routing-example-workflow",
  "displayName": "Loopstack Dynamic Routing Example Worflow",
  "description": "A workflow demonstrating how to create dynamic routing an a workflow",
  "keywords": [
    "example",
    "if",
    "routing",
    "transition",
    "workflow"
  ],
  "version": "0.21.7",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.29.0",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "loopstack": {
    "modules": [
      {
        "path": "src/dynamic-routing-example.module.ts",
        "className": "DynamicRoutingExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/dynamic-routing-example.workflow.ts",
        "className": "DynamicRoutingExampleWorkflow",
        "propertyName": "dynamicRoutingExample"
      }
    ],
    "installModes": [
      "add",
      "install"
    ]
  },
  "type": "module",
  "devDependencies": {
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
