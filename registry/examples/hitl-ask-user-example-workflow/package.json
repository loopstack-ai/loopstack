{
  "name": "@loopstack/hitl-ask-user-example-workflow",
  "displayName": "HITL Ask User Example",
  "description": "Example workflow that uses @loopstack/hitl's AskUserWorkflow to prompt the user for free-text input and echoes the answer back",
  "keywords": [
    "example",
    "hitl",
    "ask-user",
    "human-in-the-loop",
    "workflow"
  ],
  "version": "0.21.5",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://github.com/loopstack-ai"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.27.0",
    "@loopstack/core": "^0.27.0",
    "@loopstack/hitl": "^0.1.1",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "loopstack": {
    "modules": [
      {
        "path": "src/hitl-ask-user-example.module.ts",
        "className": "HitlAskUserExampleModule"
      }
    ],
    "workflows": [
      {
        "path": "src/hitl-ask-user-example.workflow.ts",
        "className": "HitlAskUserExampleWorkflow",
        "propertyName": "hitlAskUserExample"
      }
    ],
    "installModes": [
      "add",
      "install"
    ]
  }
}
