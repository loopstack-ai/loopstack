{
  "name": "@loopstack/sandbox-tool",
  "displayName": "Sandbox Tool",
  "description": "Provides isolated execution environments for running untrusted or experimental code within Loopstack workflows",
  "keywords": [
    "docker",
    "isolated-execution",
    "loopstack",
    "sandbox"
  ],
  "version": "0.7.0",
  "license": "MIT",
  "author": {
    "name": "Tobias Blättermann, Jakob Klippel"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.32.0",
    "@nestjs/common": "^11.1.19",
    "dockerode": "^4.0.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  },
  "files": [
    "dist"
  ],
  "type": "module"
}
