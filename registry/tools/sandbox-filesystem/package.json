{
  "name": "@loopstack/sandbox-filesystem",
  "displayName": "Sandbox Filesystem",
  "description": "Secure, controlled filesystem operations within Docker sandbox environments",
  "keywords": [
    "docker",
    "filesystem",
    "sandbox"
  ],
  "version": "0.7.6",
  "license": "MIT",
  "author": {
    "name": "Tobias Blättermann, Jakob Klippel"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.37.0",
    "@loopstack/sandbox-tool": "^0.7.6"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "zod": "^4.0.0"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "type": "module"
}
