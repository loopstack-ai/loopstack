{
  "name": "@loopstack/remote-file-explorer-module",
  "displayName": "Loopstack Remote File Explorer Module",
  "description": "Remote file browsing for Loopstack workspaces — proxies file tree and content requests to remote agents",
  "keywords": [
    "loopstack",
    "file-explorer",
    "remote-agent",
    "workflow"
  ],
  "version": "0.25.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.36.0",
    "@loopstack/remote-client": "^0.26.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "typeorm": "^0.3.28"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "typeorm": "^0.3.0"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "maxWorkers": 1
  },
  "type": "module"
}
