{
  "name": "@loopstack/github-module",
  "displayName": "GitHub Module",
  "description": "GitHub integration for the Loopstack automation framework. Provides a GitHub OAuth provider and tools for GitHub services such as repositories, issues, pull requests, actions, and more.",
  "keywords": [
    "authentication",
    "github",
    "loopstack",
    "module",
    "oauth"
  ],
  "version": "1.0.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@loopstack/common": "^1.0.0",
    "@loopstack/oauth-module": "^1.0.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@loopstack/common": "^1.0.0",
    "@loopstack/oauth-module": "^1.0.0",
    "zod": "^4.0.0"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "maxWorkers": 1
  },
  "type": "module"
}
