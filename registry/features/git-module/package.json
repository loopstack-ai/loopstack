{
  "name": "@loopstack/git-module",
  "displayName": "Loopstack Git Module",
  "description": "Git version control tools and API for Loopstack workspaces — commit, push, pull, branch, and more",
  "keywords": [
    "loopstack",
    "git",
    "version-control",
    "remote-agent",
    "workflow"
  ],
  "version": "0.3.3",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.34.0",
    "@loopstack/remote-client": "^0.25.3"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "@swc/core": "^1.15.33",
    "typeorm": "^0.3.28",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.6",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "typeorm": "^0.3.0",
    "zod": "^4.0.0"
  },
  "files": [
    "dist"
  ],
  "type": "module"
}
