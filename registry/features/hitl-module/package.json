{
  "name": "@loopstack/hitl",
  "displayName": "Loopstack Human-in-the-Loop",
  "description": "Human-in-the-loop workflows for Loopstack — ask questions, present options, and request confirmations from users during workflow execution",
  "keywords": [
    "loopstack",
    "hitl",
    "human-in-the-loop",
    "workflow",
    "user-input"
  ],
  "version": "0.1.1",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.27.0",
    "@loopstack/core": "^0.27.0",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "maxWorkers": 1
  },
  "loopstack": {
    "modules": [
      {
        "path": "src/hitl.module.ts",
        "className": "HitlModule"
      }
    ],
    "installModes": [
      "install"
    ]
  }
}
