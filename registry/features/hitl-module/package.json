{
  "name": "@loopstack/hitl",
  "displayName": "Loopstack Human-in-the-Loop",
  "description": "Human-in-the-loop workflows for Loopstack — ask questions, present options, and request confirmations from users during workflow execution",
  "keywords": [
    "loopstack",
    "hitl",
    "human-in-the-loop",
    "workflow",
    "user-input"
  ],
  "version": "0.4.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.32.0",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "devDependencies": {
    "@loopstack/core": "^0.32.0",
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
