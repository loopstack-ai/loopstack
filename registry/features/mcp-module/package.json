{
  "name": "@loopstack/mcp-module",
  "displayName": "Loopstack MCP Module",
  "description": "Workflow tools to list and call tools on remote MCP servers over Streamable HTTP, with host allowlisting and SSRF mitigations.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "loopstack",
    "tool"
  ],
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.29.0",
    "@loopstack/core": "^0.29.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
