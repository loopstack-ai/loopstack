{
  "name": "@loopstack/quota",
  "displayName": "Loopstack Quota Module",
  "description": "Opt-in quota tracking and enforcement for Loopstack workflows",
  "keywords": [
    "loopstack",
    "quota",
    "rate-limiting",
    "redis",
    "workflow"
  ],
  "version": "0.22.3",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.28.0",
    "@nestjs/common": "^11.1.19",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "maxWorkers": 1
  },
  "loopstack": {
    "modules": [
      {
        "path": "src/quota.module.ts",
        "className": "QuotaModule"
      }
    ],
    "installModes": [
      "install"
    ]
  }
}
