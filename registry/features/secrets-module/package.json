{
  "name": "@loopstack/secrets-module",
  "displayName": "Loopstack Secrets Module",
  "description": "Secrets management for Loopstack workflows — entity, service, tools, and REST API for securely storing and retrieving workspace secrets",
  "keywords": [
    "loopstack",
    "secrets",
    "environment-variables",
    "workflow"
  ],
  "version": "0.24.1",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.31.0",
    "@loopstack/core": "^0.31.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.6"
  }
}
