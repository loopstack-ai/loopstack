{
  "name": "@loopstack/remote-client",
  "displayName": "Loopstack Remote Client",
  "description": "Remote client and tools for Loopstack workflows — HTTP client for communicating with remote server processes, plus workflow tools for file operations, command execution, and environment management",
  "keywords": [
    "loopstack",
    "remote-client",
    "sandbox",
    "workflow",
    "tools"
  ],
  "version": "0.24.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.30.0",
    "@loopstack/core": "^0.30.0",
    "@loopstack/secrets-module": "^0.24.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "devDependencies": {
    "vitest": "^4.1.6",
    "@swc/core": "^1.15.33",
    "unplugin-swc": "^1.5.9"
  }
}
