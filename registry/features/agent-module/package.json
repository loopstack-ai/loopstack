{
  "name": "@loopstack/agent",
  "displayName": "Loopstack Agent",
  "description": "Generic LLM agent workflow for Loopstack — configurable agent loop with tool calling, error handling, and cancel support",
  "keywords": [
    "loopstack",
    "agent",
    "ai",
    "llm",
    "workflow"
  ],
  "version": "0.4.1",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.31.0",
    "@loopstack/llm-provider-module": "^0.3.1",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@loopstack/core": "^0.31.0"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testTimeout": 10000,
    "forceExit": true,
    "maxWorkers": 1
  },
  "type": "module"
}
