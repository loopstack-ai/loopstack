{
  "name": "@loopstack/github-integration",
  "displayName": "Loopstack GitHub Integration",
  "description": "GitHub integration workflows for Loopstack — connect workspaces to GitHub repositories with OAuth, push, pull, and sync",
  "keywords": [
    "loopstack",
    "github",
    "git",
    "integration",
    "workflow"
  ],
  "version": "0.2.1",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.28.0",
    "@loopstack/core": "^0.28.0",
    "@loopstack/git-module": "^0.1.2",
    "@loopstack/github-module": "^0.2.4",
    "@loopstack/hitl": "^0.1.2",
    "@loopstack/oauth-module": "^0.2.6",
    "@loopstack/remote-client": "^0.23.3",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "maxWorkers": 1
  },
  "loopstack": {
    "modules": [
      {
        "path": "src/github-integration.module.ts",
        "className": "GitHubIntegrationModule"
      }
    ],
    "installModes": [
      "install"
    ]
  }
}
