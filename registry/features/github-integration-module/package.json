{
  "name": "@loopstack/github-integration",
  "displayName": "Loopstack GitHub Integration",
  "description": "GitHub integration workflows for Loopstack — connect workspaces to GitHub repositories with OAuth, push, pull, and sync",
  "keywords": [
    "loopstack",
    "github",
    "git",
    "integration",
    "workflow"
  ],
  "version": "0.4.3",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.34.0",
    "@loopstack/core": "^0.34.0",
    "@loopstack/git-module": "^0.3.3",
    "@loopstack/github-module": "^0.4.3",
    "@loopstack/hitl": "^0.4.3",
    "@loopstack/oauth-module": "^0.4.3",
    "@loopstack/remote-client": "^0.25.3"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "zod": "^4.0.0"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "maxWorkers": 1
  },
  "type": "module"
}
