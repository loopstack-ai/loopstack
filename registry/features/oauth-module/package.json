{
  "name": "@loopstack/oauth-module",
  "displayName": "Loopstack OAuth Module",
  "description": "A provider-agnostic OAuth 2.0 module for the Loopstack automation framework. Provides a generic OAuth workflow, token storage, and a provider registry so any OAuth provider (Google, Microsoft, GitHub, etc.) can be plugged in.",
  "keywords": [
    "authentication",
    "loopstack",
    "module",
    "oauth"
  ],
  "version": "0.4.6",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/common": "^0.37.0",
    "@loopstack/core": "^0.37.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "ioredis": "^5.10.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.6",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0",
    "zod": "^4.0.0"
  },
  "files": [
    "dist"
  ],
  "type": "module"
}
