{
  "name": "@loopstack/code-agent",
  "displayName": "Loopstack Code Agent",
  "description": "AI-powered code agent workflows for Loopstack — codebase exploration, analysis, and more",
  "keywords": [
    "loopstack",
    "code-agent",
    "ai",
    "exploration",
    "workflow"
  ],
  "version": "0.2.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/agent": "^0.2.0",
    "@loopstack/common": "^0.28.0",
    "@loopstack/core": "^0.28.0",
    "@loopstack/remote-client": "^0.23.3",
    "@nestjs/common": "^11.1.19",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "maxWorkers": 1
  },
  "loopstack": {
    "modules": [
      {
        "path": "src/code-agent.module.ts",
        "className": "CodeAgentModule"
      }
    ],
    "tools": [
      {
        "package": "@loopstack/remote-client",
        "className": "GlobTool",
        "propertyName": "glob"
      },
      {
        "package": "@loopstack/remote-client",
        "className": "GrepTool",
        "propertyName": "grep"
      },
      {
        "package": "@loopstack/remote-client",
        "className": "ReadTool",
        "propertyName": "read"
      }
    ],
    "installModes": [
      "install"
    ]
  }
}
