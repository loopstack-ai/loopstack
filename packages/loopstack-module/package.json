{
  "name": "@loopstack/loopstack-module",
  "displayName": "Loopstack Module",
  "description": "All-in-one NestJS module for bootstrapping a Loopstack application",
  "version": "0.31.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "nest build",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "watch": "nest build --watch"
  },
  "dependencies": {
    "@loopstack/api": "^0.32.0",
    "@loopstack/auth": "^0.32.0",
    "@loopstack/common": "^0.32.0",
    "@loopstack/contracts": "^0.32.0",
    "@loopstack/core": "^0.32.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/typeorm": "^11.0.1",
    "pg": "^8.20.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {},
  "files": [
    "dist",
    "docker-compose.yml",
    "docker-compose.infra.yml"
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
