{
  "name": "@loopstack/react",
  "displayName": "Loopstack React",
  "description": "React adapter for the Loopstack SDK — provider, TanStack Query hooks, and live stream bindings",
  "version": "0.0.0",
  "license": "MIT",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "compile": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "watch": "tsc -p tsconfig.build.json --watch"
  },
  "dependencies": {
    "@loopstack/contracts": "^0.36.0"
  },
  "peerDependencies": {
    "@loopstack/client": "^0.36.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@loopstack/client": "^0.36.0",
    "@tanstack/react-query": "^5.99.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "jsdom": "^29.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vitest": "^4.1.6"
  },
  "files": [
    "dist"
  ]
}
