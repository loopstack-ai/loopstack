{
  "name": "loopstack",
  "displayName": "Loopstack AI Workflow Automation Framework",
  "description": "A monorepo to maintain loopstack core modules, templates and frontend applications",
  "version": "0.17.10",
  "author": {
    "name": "Jakob Klippel",
    "url": "https://www.linkedin.com/in/jakob-klippel/"
  },
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/",
    "prepare": "husky",
    "test": "turbo run test --continue",
    "watch": "turbo run watch",
    "changeset:version": "changeset version && npm install --package-lock-only --prefer-offline"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/testing": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "syncpack": "^14.3.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "bullmq": "^5.73.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "turbo": "^2.9.6",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --check"
    ]
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/*",
    "frontend/*",
    "registry/*/*",
    "services/*",
    "sandbox/hello-world",
    "sandbox/smoke-tests",
    "sandbox/acceptance-harness"
  ]
}
